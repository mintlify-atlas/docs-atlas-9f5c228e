  "keyFeatures": [
    "Type-safe Salesforce authentication with async/await support",
    "Comprehensive church member data models with field expansion",
    "Family relationship tracking and management",
    "Seeker (visitor) management and tracking",
    "File operations for Salesforce content downloads",
    "Rich date handling with age calculations and anniversary tracking",
    "Discipleship journey tracking (baptism, courses, ministry involvement)",
    "Support for macOS and iOS applications",
    "Compatible with Vapor and Hummingbird server frameworks"
  ],
